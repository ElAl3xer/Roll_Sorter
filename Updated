import os
import tkinter as tk
from tkinter import filedialog, ttk
from moviepy import VideoFileClip
import librosa
import tempfile
import shutil
import threading
import numpy as np
 
UPPER_THRESHOLD = 0.25
LOWER_THRESHOLD = 0.08
 #BS FUNCTIONS
def audioanalyzer(file_path):
    video = None
    temp_path = None

    try:
        speech_frames = 0
        video = VideoFileClip(file_path)
        if video.audio is None:
            return 0.0
        with tempfile.NamedTemporaryFile(delete=False, suffix=".wav") as temp_file:
            temp_path = temp_file.name
        video.audio.write_audiofile(
            temp_path,
            logger=None
        )
        y, sr = librosa.load(temp_path, sr=16000)
        rms = librosa.feature.rms(y=y)[0]
        rms_db = librosa.amplitude_to_db(rms, ref=1.0)
        for db in rms_db:
            if db > -25:
                speech_frames += 1
        speech_ratio = speech_frames / len(rms_db)
        return speech_ratio
    finally:
        if video is not None:
            video.close()
        if temp_path and os.path.exists(temp_path):
            os.remove(temp_path)
 
def classify(speech_ratio):
    if speech_ratio > UPPER_THRESHOLD:
        return "A_roll"
    if speech_ratio < UPPER_THRESHOLD and speech_ratio > LOWER_THRESHOLD:
        return "Review"
    else:
        return "B_roll"
 
def sort_files(folder_path, progress_callback, status_callback):
    folder_files = os.listdir(folder_path)
    video_files = [f for f in folder_files if f.endswith((".mp4", ".mov")) and os.path.isfile(os.path.join(folder_path, f))]
 
    if not video_files:
        status_callback("No video files found in folder.")
        return
 
    total = len(video_files)
    for i, file in enumerate(video_files):
        status_callback(f"Analyzing {file}...")
        file_path = os.path.join(folder_path, file)
        try:
            audio_score = audioanalyzer(file_path)
            theclass = classify(audio_score)
            dest_folder = os.path.join(folder_path, theclass)
            os.makedirs(dest_folder, exist_ok=True)
            shutil.move(file_path, dest_folder)
        except Exception as e:
            status_callback(f"Skipped {file}: {e}")
        progress_callback(int((i + 1) / total * 100))
 
    status_callback("Done! All files sorted.")
 
 
#GUI
 
def pick_folder():
    path = filedialog.askdirectory(title="Select project folder")
    if path:
        folder_var.set(path)
        status_var.set("Ready. Press Sort to begin.")
        progress["value"] = 0
 
def start_sort():
    folder = folder_var.get()
    if folder == "No folder selected":
        status_var.set("Please select a folder first.")
        return
 
    sort_btn.config(state="disabled")
    progress["value"] = 0
 
    def run():
        sort_files(
            folder,
            progress_callback=lambda v: root.after(0, lambda: progress.configure(value=v)),
            status_callback=lambda msg: root.after(0, lambda: status_var.set(msg))
        )
        root.after(0, lambda: sort_btn.config(state="normal"))
 
    threading.Thread(target=run, daemon=True).start()
 
 
